<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Clientes</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

    <%- include('../partials/nav') %>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="mb-0">Clientes</h1>
            <a href="/clientes/novo" class="btn btn-success btn-sm">+ Novo</a>
        </div>

        <div class="d-none d-md-block">
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>E-mail</th>
                    </tr>
                </thead>
                <tbody>
                    <% clientes.forEach(cliente => { %>
                        <tr>
                            <td><%= cliente.id %></td>
                            <td><%= cliente.nome %></td>
                            <td><%= cliente.email %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <div class="d-md-none">
            <% clientes.forEach(cliente => { %>
                <div class="card mb-3 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title"><%= cliente.nome %></h5>
                        <p class="card-text text-muted">ID: <%= cliente.id %></p>
                        <p class="card-text text-muted">E-mail: <%= cliente.email %></p>
                    </div>
                </div>
            <% }) %>
        </div>

        <div class="mt-3">
            <a href="/" class="btn btn-secondary w-100 mt-3">Voltar</a>
        </div>
    </div>

    <%- include('../partials/footer') %>

</body>
</html>