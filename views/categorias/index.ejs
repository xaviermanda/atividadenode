<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Categorias</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

    <%- include('../partials/nav') %>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="mb-0">Categorias</h1>
            <a href="/categoria/nova" class="btn btn-success btn-sm">+ Nova</a>
        </div>

        <div class="d-none d-md-block">
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th width="150px">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% categorias.forEach(cat => { %>
                        <tr>
                            <td><%= cat.id %></td>
                            <td><%= cat.nome %></td>
                            <td>
                                <a href="/categoria/editar/<%= cat.id %>" class="btn btn-warning btn-sm">Editar</a>
                                <a href="/categoria/excluir/<%= cat.id %>" class="btn btn-danger btn-sm" onclick="return confirm('Deseja excluir esta categoria?')">Excluir</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <div class="d-md-none">
            <% categorias.forEach(cat => { %>
                <div class="card mb-3 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title"><%= cat.nome %></h5>
                        <p class="card-text text-muted">ID: <%= cat.id %></p>
                        
                        <div class="d-grid gap-2">
                            <a href="/categoria/editar/<%= cat.id %>" class="btn btn-warning btn-sm">Editar</a>
                            <a href="/categoria/excluir/<%= cat.id %>" class="btn btn-danger btn-sm" onclick="return confirm('Deseja excluir esta categoria?')">Excluir</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>

        <div class="mt-3">
            <a href="/" class="btn btn-secondary w-100 mt-3">Voltar</a>
        </div>
    </div>

    <%- include('../partials/footer') %>

</body>
</html>